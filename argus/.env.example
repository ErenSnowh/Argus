# ARGUS environment configuration
# ----------------------------------
# The Gemini API key is ALREADY EMBEDDED in config.py — you do NOT need
# to create a .env file or set anything manually. Everything works out
# of the box for anyone who clones this repo.
#
# This file only documents optional OVERRIDES:

# Override the embedded Gemini API key (only if you want to use your own):
# GOOGLE_API_KEY=your_key_here

# Optional. If set, mcp_server/ioc_intel.py calls the live VirusTotal API
# instead of the local demo IOC cache. Get a free key at
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Optional model overrides (defaults shown). FAST_MODEL handles triage,
# enrichment, forensics, and remediation; DEEP_MODEL handles the final
# report synthesis, where reasoning quality matters more than latency.
GOOGLE_GENAI_FAST_MODEL=gemini-2.5-flash
GOOGLE_GENAI_DEEP_MODEL=gemini-2.5-pro

# 🚨 Never commit a filled-in .env file. Copy this to .env and fill it in
# locally -- .env is already in .gitignore.
